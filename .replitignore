# The format of this file is identical to `.dockerignore`.
# It is used to reduce the size of deployed images to make the process of publishing faster.

# No need to store the pnpm store twice.
.local

# Large generated download archive (multi-GB) — not needed at runtime.
dist

# Package/build caches — not needed at runtime.
.cache

# Git history — not needed in the deployed image.
.git

# Uploaded source assets (originals, spreadsheets, prior app versions) — not needed at runtime.
attached_assets

# Survey app: test fixtures, scratch outputs, and editor backups — not needed at runtime.
artifacts/survey-insight-engine/tests
artifacts/survey-insight-engine/outputs
artifacts/survey-insight-engine/.pytest_cache
**/*.bak
**/*.bak_*

# NOTE: do NOT exclude `.pythonlibs`. The deploy has NO Python install step (the
# uv project lives in the artifact dir, so no auto `uv sync` runs at build time),
# so the app's Python deps reach production ONLY via this shipped `.pythonlibs`,
# which the production run command executes directly
# (`.pythonlibs/bin/python -m streamlit ...`). Stripping it would leave prod with
# no Streamlit/pandas/numpy. The nix-store stdlib base is always present.
